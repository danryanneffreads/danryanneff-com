---
import BaseLayout from '../layouts/BaseLayout.astro';
import { seoMetadata } from '../lib/constants';

const pageMetadata = seoMetadata['/mandalafy/'];
---

<BaseLayout
  title={pageMetadata.title}
  description={pageMetadata.description}
>
  <section class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8 py-16 md:py-24">
    <h1 class="text-5xl md:text-6xl font-bold text-gray-900 dark:text-white mb-8">
      Mandalafy
    </h1>

    <p class="text-2xl text-gray-600 dark:text-gray-400 mb-12">
      An interactive tool for creating and exploring mandalas. Coming soon.
    </p>

    <!-- Placeholder Content -->
    <div class="bg-gray-50 dark:bg-gray-800 rounded-lg p-12 text-center mb-12">
      <p class="text-lg text-gray-600 dark:text-gray-400 mb-8">
        This project page is currently being built. Check back soon for more details and the interactive tool.
      </p>

      <div class="space-x-4">
        <a
          href="/"
          class="inline-block px-8 py-3 bg-blue-600 hover:bg-blue-700 dark:bg-blue-500 dark:hover:bg-blue-600 text-white font-semibold rounded-lg transition-colors"
        >
          Back to Home
        </a>
        <a
          href="/work-with-me/"
          class="inline-block px-8 py-3 border-2 border-blue-600 dark:border-blue-500 text-blue-600 dark:text-blue-400 hover:bg-blue-50 dark:hover:bg-gray-700 font-semibold rounded-lg transition-colors"
        >
          Explore Services
        </a>
      </div>
    </div>

    <!-- Project Details Grid -->
    <div class="grid grid-cols-1 md:grid-cols-2 gap-8 mb-12">
      <div class="bg-white dark:bg-gray-800 p-8 rounded-lg border border-gray-200 dark:border-gray-700">
        <h2 class="text-2xl font-bold text-gray-900 dark:text-white mb-4">
          About Mandalafy
        </h2>
        <p class="text-gray-600 dark:text-gray-400">
          Mandalafy is an interactive digital tool for creating, exploring, and sharing custom mandalas. 
          It combines geometric patterns, symmetry, and interactivity to create unique visual experiences.
        </p>
      </div>

      <div class="bg-white dark:bg-gray-800 p-8 rounded-lg border border-gray-200 dark:border-gray-700">
        <h2 class="text-2xl font-bold text-gray-900 dark:text-white mb-4">
          Features
        </h2>
        <ul class="space-y-2 text-gray-600 dark:text-gray-400">
          <li class="flex gap-2">
            <span class="text-blue-600 dark:text-blue-400 font-bold">✓</span>
            <span>Interactive creation</span>
          </li>
          <li class="flex gap-2">
            <span class="text-blue-600 dark:text-blue-400 font-bold">✓</span>
            <span>Real-time preview</span>
          </li>
          <li class="flex gap-2">
            <span class="text-blue-600 dark:text-blue-400 font-bold">✓</span>
            <span>Export options</span>
          </li>
          <li class="flex gap-2">
            <span class="text-blue-600 dark:text-blue-400 font-bold">✓</span>
            <span>Gallery sharing</span>
          </li>
        </ul>
      </div>
    </div>

    <!-- CTA Section -->
    <div class="bg-gradient-to-r from-blue-50 to-blue-100 dark:from-gray-800 dark:to-gray-700 rounded-lg p-12 text-center">
      <h2 class="text-3xl font-bold text-gray-900 dark:text-white mb-4">
        Interested in Learning More?
      </h2>
      <p class="text-lg text-gray-600 dark:text-gray-400 mb-8">
        Let's discuss how this type of project could serve your goals.
      </p>
      <a
        href="/contact/"
        class="inline-block px-8 py-3 bg-blue-600 hover:bg-blue-700 dark:bg-blue-500 dark:hover:bg-blue-600 text-white font-semibold rounded-lg transition-colors"
      >
        Get in Touch
      </a>
    </div>
  </section>
</BaseLayout>
