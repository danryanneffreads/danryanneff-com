---
import BaseLayout from '../layouts/BaseLayout.astro';
import { seoMetadata } from '../lib/constants';

const pageMetadata = seoMetadata['/contact/'];
---

<BaseLayout title={pageMetadata.title} description={pageMetadata.description}>
  <section class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8 py-16 md:py-24">
    <p class="text-sm uppercase tracking-widest text-gray-500 dark:text-gray-400 mb-4">
      Contact
    </p>

    <h1 class="text-5xl md:text-6xl font-bold text-gray-900 dark:text-white mb-6">
      Let’s talk.
    </h1>

    <p class="text-xl text-gray-600 dark:text-gray-400 mb-12 max-w-3xl">
      If you have a real situation, idea, website, project, or question that feels worth thinking through together, a conversation is the easiest place to start.
    </p>

    <div class="grid grid-cols-1 lg:grid-cols-[1.1fr_0.9fr] gap-8 mb-16">
      <div class="bg-blue-50 dark:bg-gray-800 border border-blue-100 dark:border-gray-700 p-8 rounded-xl">
        <p class="text-sm uppercase tracking-widest text-blue-700 dark:text-blue-400 mb-3">
          Recommended
        </p>

        <h2 class="text-3xl font-bold text-gray-900 dark:text-white mb-4">
          Book a free video conversation
        </h2>

        <p class="text-gray-600 dark:text-gray-400 mb-6">
          A low-friction way to meet, talk through what you’re working on, and see whether there may be a useful next step.
        </p>

        <p class="text-gray-600 dark:text-gray-400 mb-8">
          This is especially useful if you’re thinking about a website, AI, operations, communication, a project, or a decision that would benefit from another perspective.
        </p>

        <a
          href="https://cal.com/danryanneff/conversation"
          target="_blank"
          rel="noopener"
          class="inline-block px-8 py-3 bg-blue-600 hover:bg-blue-700 text-white font-semibold rounded-lg transition-colors"
        >
          Book a free conversation
        </a>
      </div>

      <div class="bg-gray-50 dark:bg-gray-800 border border-gray-200 dark:border-gray-700 p-8 rounded-xl">
        <p class="text-sm uppercase tracking-widest text-gray-500 dark:text-gray-400 mb-3">
          Focused work
        </p>

        <h2 class="text-3xl font-bold text-gray-900 dark:text-white mb-4">
          Book a working session
        </h2>

        <p class="text-gray-600 dark:text-gray-400 mb-6">
          If you already have a specific challenge, decision, website, system, or project in mind, a working session gives us dedicated time to focus on it.
        </p>

        <a
          href="https://cal.com/danryanneff/working-session"
          target="_blank"
          rel="noopener"
          class="inline-block px-8 py-3 border-2 border-blue-600 text-blue-600 dark:text-blue-400 dark:border-blue-500 hover:bg-blue-50 dark:hover:bg-gray-900 font-semibold rounded-lg transition-colors"
        >
          Book a working session
        </a>
      </div>
    </div>

    <section class="max-w-3xl">
      <h2 class="text-3xl font-bold text-gray-900 dark:text-white mb-4">
        Or send a message
      </h2>

      <p class="text-gray-600 dark:text-gray-400 mb-8">
        Use the form if you prefer to share a few details first. I personally read every message.
      </p>

      <form
        action="https://formspree.io/f/mvzndpja"
        method="POST"
        class="space-y-6"
            >
        <input
          type="text"
          name="_gotcha"
          class="hidden"
          tabindex="-1"
          autocomplete="off"
          aria-hidden="true"
        />

        <div>
        <div>
          <label for="email" class="block text-sm font-medium text-gray-900 dark:text-white mb-2">
            Email Address *
          </label>
          <input
            type="email"
            id="email"
            name="email"
            required
            placeholder="your@email.com"
            class="w-full px-4 py-3 bg-white dark:bg-gray-800 border border-gray-300 dark:border-gray-600 rounded-lg text-gray-900 dark:text-white placeholder-gray-400 dark:placeholder-gray-500 focus:outline-none focus:ring-2 focus:ring-blue-600 dark:focus:ring-blue-500 transition-all"
          />
        </div>

        <div>
          <label for="subject" class="block text-sm font-medium text-gray-900 dark:text-white mb-2">
            Subject *
          </label>
          <input
            type="text"
            id="subject"
            name="subject"
            required
            placeholder="What this is about"
            class="w-full px-4 py-3 bg-white dark:bg-gray-800 border border-gray-300 dark:border-gray-600 rounded-lg text-gray-900 dark:text-white placeholder-gray-400 dark:placeholder-gray-500 focus:outline-none focus:ring-2 focus:ring-blue-600 dark:focus:ring-blue-500 transition-all"
          />
        </div>

        <div>
          <label for="message" class="block text-sm font-medium text-gray-900 dark:text-white mb-2">
            Message *
          </label>
          <textarea
            id="message"
            name="message"
            required
            placeholder="Project inquiry, question, or introduction... whatever you'd like to share."
            rows={6}
            class="w-full px-4 py-3 bg-white dark:bg-gray-800 border border-gray-300 dark:border-gray-600 rounded-lg text-gray-900 dark:text-white placeholder-gray-400 dark:placeholder-gray-500 focus:outline-none focus:ring-2 focus:ring-blue-600 dark:focus:ring-blue-500 transition-all resize-none"
          ></textarea>
        </div>

        <button
          type="submit"
          class="w-full sm:w-auto px-8 py-3 bg-blue-600 hover:bg-blue-700 text-white font-semibold rounded-lg transition-colors cursor-pointer"
        >
          Send message
        </button>
      </form>
    </section>
  </section>
</BaseLayout>