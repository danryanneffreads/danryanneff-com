---
import BaseLayout from "../layouts/BaseLayout.astro";

const calUrl = "https://cal.com/danryanneff/conversation";
const emailAddress = "danryannneff@gmail.com";
---

<BaseLayout
  title="Contact"
  description="Schedule a conversation, follow along by email, or get in touch directly."
>
  <main>
    <section class="hero">
      <div class="hero__content">
        <p class="eyebrow">Contact</p>

        <h1>Let’s continue the conversation.</h1>

        <p class="hero__intro">
          Whether you have a question, an idea, or simply want to connect,
          I’d be glad to hear from you.
        </p>
      </div>

      <div class="hero__art" aria-hidden="true">
        <img
          src="/images/orange-loops-green-background.webp"
          alt=""
          width="660"
          height="660"
        />
      </div>
    </section>

    <section class="contact-options" aria-label="Ways to connect">
      <article class="contact-option">
        <p class="contact-option__number" aria-hidden="true">01</p>

        <div class="contact-option__content">
          <h2>Let’s talk</h2>

          <p>
            Some conversations become collaborations. Others simply help
            clarify an idea.
          </p>

          <a
            class="button"
            href={calUrl}
            target="_blank"
            rel="noopener noreferrer"
          >
            Schedule a conversation
            <span aria-hidden="true">↗</span>
          </a>
        </div>
      </article>

      <article class="contact-option">
        <p class="contact-option__number" aria-hidden="true">02</p>

        <div class="contact-option__content">
          <h2>Follow along</h2>

          <p>
            I occasionally share thoughts, projects, and questions I’m
            exploring. You can receive them by email.
          </p>

          <div class="email-signup">
            <iframe
              src="https://embeds.beehiiv.com/7b7905fd-bdf1-49b9-9cbc-754021ddf12e?slim=true"
              data-test-id="beehiiv-embed"
              title="Join my email list"
              height="52"
              frameborder="0"
              scrolling="no"
            ></iframe>
          </div>
        </div>
      </article>

      <article class="contact-option">
        <p class="contact-option__number" aria-hidden="true">03</p>

        <div class="contact-option__content">
          <h2>Email me</h2>

          <p>
            You can also reach me directly at:
          </p>

          <a class="email-link" href={`mailto:${emailAddress}`}>
            {emailAddress}
          </a>
        </div>
      </article>
    </section>

    <section class="closing">
      <div class="closing__art" aria-hidden="true">
        <img
          src="/images/mandala-blue-labyrinth-660.webp"
          alt=""
          width="660"
          height="660"
          loading="lazy"
        />
      </div>

      <div class="closing__content">
        <p>I’d enjoy hearing what you’re exploring.</p>
      </div>
    </section>
  </main>
</BaseLayout>

<style>
  main {
    overflow: hidden;
  }

  .hero,
  .contact-options,
  .closing {
    width: min(1120px, calc(100% - 2rem));
    margin-inline: auto;
  }

  .hero {
    display: grid;
    grid-template-columns: minmax(0, 1.15fr) minmax(280px, 0.85fr);
    align-items: center;
    gap: clamp(3rem, 8vw, 7rem);
    min-height: 72vh;
    padding-block: clamp(5rem, 11vw, 9rem);
  }

  .hero__content {
    max-width: 720px;
  }

  .eyebrow {
    margin: 0 0 1.25rem;
    font-size: 0.78rem;
    font-weight: 600;
    letter-spacing: 0.14em;
    text-transform: uppercase;
  }

  h1 {
    max-width: 760px;
    margin: 0;
    font-size: clamp(3.2rem, 7vw, 6.8rem);
    font-weight: 450;
    line-height: 0.98;
    letter-spacing: -0.055em;
    text-wrap: balance;
  }

  .hero__intro {
    max-width: 600px;
    margin: 2rem 0 0;
    font-size: clamp(1.15rem, 2vw, 1.45rem);
    line-height: 1.6;
  }

  .hero__art img,
  .closing__art img {
    display: block;
    width: 100%;
    height: auto;
  }

  .hero__art img {
    border-radius: 50%;
  }

  .contact-options {
    border-top: 1px solid currentColor;
  }

  .contact-option {
    display: grid;
    grid-template-columns: minmax(3rem, 0.25fr) minmax(0, 1fr);
    gap: clamp(1.5rem, 5vw, 5rem);
    padding-block: clamp(3rem, 7vw, 5rem);
    border-bottom: 1px solid currentColor;
  }

  .contact-option__number {
    margin: 0.5rem 0 0;
    font-size: 0.78rem;
    letter-spacing: 0.12em;
  }

  .contact-option__content {
    width: 100%;
    max-width: 720px;
  }

  h2 {
    margin: 0;
    font-size: clamp(2rem, 4.5vw, 4rem);
    font-weight: 450;
    line-height: 1.05;
    letter-spacing: -0.04em;
  }

  .contact-option__content p {
    max-width: 620px;
    margin: 1.25rem 0 0;
    font-size: clamp(1.05rem, 1.8vw, 1.25rem);
    line-height: 1.65;
  }

  .button,
  .email-link {
    display: inline-flex;
    align-items: center;
    gap: 0.55rem;
    margin-top: 2rem;
    color: inherit;
    font-weight: 600;
    text-underline-offset: 0.25em;
  }

  .button {
    padding: 0.9rem 1.2rem;
    border: 1px solid currentColor;
    border-radius: 999px;
    text-decoration: none;
    transition:
      opacity 160ms ease,
      transform 160ms ease;
  }

  .button:hover {
    opacity: 0.72;
    transform: translateY(-2px);
  }

  .email-link {
    font-size: 1.05rem;
    overflow-wrap: anywhere;
  }

  .button:focus-visible,
  .email-link:focus-visible {
    outline: 3px solid currentColor;
    outline-offset: 5px;
  }

  .email-signup {
    width: 100%;
    max-width: 620px;
    margin-top: 2rem;
    overflow: hidden;
  }

  .email-signup iframe {
    display: block;
    width: 100%;
    min-height: 52px;
    margin: 0;
    border: 0;
    background-color: transparent;
  }

  .closing {
    display: grid;
    grid-template-columns: minmax(240px, 0.75fr) minmax(0, 1.25fr);
    align-items: center;
    gap: clamp(3rem, 8vw, 7rem);
    padding-block: clamp(5rem, 11vw, 10rem);
  }

  .closing__art {
    max-width: 420px;
  }

  .closing__content p {
    max-width: 700px;
    margin: 0;
    font-size: clamp(1.8rem, 4vw, 3.6rem);
    line-height: 1.15;
    letter-spacing: -0.035em;
    text-wrap: balance;
  }

  @media (max-width: 760px) {
    .hero,
    .closing {
      grid-template-columns: 1fr;
    }

    .hero {
      min-height: auto;
      padding-top: 5rem;
    }

    .hero__art {
      width: min(78vw, 420px);
      margin-inline: auto;
    }

    .contact-option {
      grid-template-columns: 1fr;
      gap: 1rem;
    }

    .contact-option__number {
      margin: 0;
    }

    .email-signup iframe {
      width: 100%;
    }

    .closing__art {
      width: min(72vw, 360px);
      margin-inline: auto;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .button {
      transition: none;
    }

    .button:hover {
      transform: none;
    }
  }
</style>