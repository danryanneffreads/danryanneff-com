---
import BaseLayout from '../layouts/BaseLayout.astro';
import { seoMetadata } from '../lib/constants';

const pageMetadata = seoMetadata['/work-with-me/'];
---

<BaseLayout title={pageMetadata.title} description={pageMetadata.description}>
  <section class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8 py-16 md:py-24">
    <p class="text-sm uppercase tracking-widest text-gray-500 dark:text-gray-400 mb-4">
      Work With Me
    </p>

    <h1 class="text-5xl md:text-6xl font-bold text-gray-900 dark:text-white mb-8 max-w-4xl">
      Start with a conversation.
    </h1>

    <p class="text-xl text-gray-600 dark:text-gray-400 mb-6 max-w-3xl">
      People come to me with all kinds of situations: websites that no longer reflect the quality of their work, operational challenges, questions about AI, new ideas, difficult decisions, and opportunities that feel hard to evaluate alone.
    </p>

    <p class="text-lg text-gray-600 dark:text-gray-400 mb-12 max-w-3xl">
      The best way to understand what I do is to bring me a real situation.
    </p>

    <div class="grid grid-cols-1 md:grid-cols-2 gap-8 mb-16">
      <div class="bg-gray-50 dark:bg-gray-800 p-8 rounded-lg">
        <p class="text-sm uppercase tracking-widest text-gray-500 dark:text-gray-400 mb-3">
          Free
        </p>

        <h2 class="text-2xl font-bold text-gray-900 dark:text-white mb-4">
          Conversation
        </h2>

        <p class="text-gray-600 dark:text-gray-400 mb-6">
          A chance to meet, exchange perspectives, and see whether there is any reason to continue the conversation. No agenda required. No expectation of a project.
        </p>

        <a href="/contact/" class="inline-block px-6 py-3 bg-blue-600 hover:bg-blue-700 text-white font-semibold rounded-lg transition-colors">
          Start a conversation
        </a>
      </div>

      <div class="bg-gray-50 dark:bg-gray-800 p-8 rounded-lg">
        <p class="text-sm uppercase tracking-widest text-gray-500 dark:text-gray-400 mb-3">
          Focused
        </p>

        <h2 class="text-2xl font-bold text-gray-900 dark:text-white mb-4">
          Working Session
        </h2>

        <p class="text-gray-600 dark:text-gray-400 mb-6">
          A dedicated session for a specific challenge, decision, opportunity, website, system, or project. We look carefully at the situation and identify meaningful next steps.
        </p>

        <a href="/contact/" class="inline-block px-6 py-3 border-2 border-blue-600 text-blue-600 dark:text-blue-400 dark:border-blue-500 hover:bg-blue-50 dark:hover:bg-gray-800 font-semibold rounded-lg transition-colors">
          Ask about a session
        </a>
      </div>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-2 gap-8">
      <div class="bg-white dark:bg-gray-800 border border-gray-200 dark:border-gray-700 p-8 rounded-lg">
        <h2 class="text-2xl font-bold text-gray-900 dark:text-white mb-6">
          What people bring to me
        </h2>

        <ul class="space-y-3 text-gray-600 dark:text-gray-400">
          <li>A website that no longer reflects the quality of their work</li>
          <li>Questions about AI and where it fits</li>
          <li>Operational challenges and communication issues</li>
          <li>Decisions that are difficult to think through alone</li>
          <li>New ideas that need structure and direction</li>
        </ul>
      </div>

      <div class="bg-white dark:bg-gray-800 border border-gray-200 dark:border-gray-700 p-8 rounded-lg">
        <h2 class="text-2xl font-bold text-gray-900 dark:text-white mb-6">
          Project work can include
        </h2>

        <ul class="space-y-3 text-gray-600 dark:text-gray-400">
          <li>Website design and building</li>
          <li>Digital tool customization</li>
          <li>Online presence and structure</li>
          <li>Operations and process improvement</li>
          <li>Team communication structure</li>
        </ul>
      </div>
    </div>
  </section>
</BaseLayout>