---
import BaseLayout from '../layouts/BaseLayout.astro';
import { seoMetadata } from '../lib/constants';

const pageMetadata = seoMetadata['/about/'];
---

<BaseLayout
  title={pageMetadata.title}
  description={pageMetadata.description}
>
  <section class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 py-16 md:py-24">
    <h1 class="text-5xl md:text-6xl font-bold text-gray-900 dark:text-white mb-8">
      About Dan
    </h1>

    <div class="prose prose-lg dark:prose-invert max-w-none">
      <p class="text-lg text-gray-600 dark:text-gray-400 mb-6">
        I work with thoughtful founders, operators, and teams who want to build with intention. My background is in operations, systems design, and digital strategy. I've spent the last decade helping organizations move from chaos to clarity.
      </p>

      <p class="text-lg text-gray-600 dark:text-gray-400 mb-6">
        I believe the best work happens when strategy, structure, and clarity align. Whether you're building a new product, scaling operations, or asking bigger questions about how to work together—I'm here to help you find the path forward.
      </p>

      <p class="text-lg text-gray-600 dark:text-gray-400 mb-6">
        My approach is conversational. I ask questions, listen carefully, and work with you to understand what matters most. Then we build the systems, strategies, and structures that make your work feel easier and more meaningful.
      </p>

      <h2 class="text-3xl font-bold text-gray-900 dark:text-white mt-12 mb-6">
        What I do
      </h2>

      <h3 class="text-2xl font-bold text-gray-900 dark:text-white mt-8 mb-4">
        Operations & Systems
      </h3>
      <p class="text-gray-600 dark:text-gray-400 mb-4">
        Clear systems create clarity. I help teams design and implement the operational frameworks that support growth—from decision-making processes to communication structures to scaling patterns.
      </p>

      <h3 class="text-2xl font-bold text-gray-900 dark:text-white mt-8 mb-4">
        Digital Strategy
      </h3>
      <p class="text-gray-600 dark:text-gray-400 mb-4">
        Digital products should serve your goals, not the other way around. I help teams think through digital strategy, product direction, and the technical and organizational patterns that support meaningful product work.
      </p>

      <h2 class="text-3xl font-bold text-gray-900 dark:text-white mt-12 mb-6">
        How to work together
      </h2>

      <p class="text-gray-600 dark:text-gray-400 mb-6">
        I offer a few different ways to engage depending on your needs:
      </p>

      <ul class="list-disc list-inside space-y-4 text-gray-600 dark:text-gray-400 mb-8">
        <li>
          <strong class="text-gray-900 dark:text-white">Clarity Sessions</strong> — One-off conversations to explore a specific challenge or opportunity
        </li>
        <li>
          <strong class="text-gray-900 dark:text-white">Working Partnerships</strong> — Ongoing engagement over weeks or months to build something specific
        </li>
        <li>
          <strong class="text-gray-900 dark:text-white">Advisory Relationships</strong> — Regular touchbases to think through strategic questions
        </li>
      </ul>

      <div class="mt-12 pt-12 border-t border-gray-200 dark:border-gray-700">
        <p class="text-lg text-gray-600 dark:text-gray-400 mb-6">
          Ready to talk? Let's find a time.
        </p>
        <a
          href="/contact/"
          class="inline-block px-8 py-3 bg-blue-600 hover:bg-blue-700 dark:bg-blue-500 dark:hover:bg-blue-600 text-white font-semibold rounded-lg transition-colors"
        >
          Start a Conversation
        </a>
      </div>
    </div>
  </section>
</BaseLayout>
