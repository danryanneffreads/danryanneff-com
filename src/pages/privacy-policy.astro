---
import BaseLayout from '../layouts/BaseLayout.astro';
import { seoMetadata } from '../lib/constants';

const pageMetadata = seoMetadata['/privacy-policy/'];
---

<BaseLayout title={pageMetadata.title} description={pageMetadata.description}>
  <section class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 py-16 md:py-24">
    <h1 class="text-5xl md:text-6xl font-bold text-gray-900 dark:text-white mb-6">
      Privacy Policy
    </h1>

    <p class="text-gray-600 dark:text-gray-400 mb-12">
      Last updated: June 2026
    </p>

    <div class="space-y-12">

      <section>
        <h2 class="text-3xl font-bold text-gray-900 dark:text-white mb-4">
          Who we are
        </h2>

        <p class="text-gray-600 dark:text-gray-400">
          DanRyanNeff.com is a personal website and portfolio operated by Dan Ryan Neff.
        </p>
      </section>

      <section>
        <h2 class="text-3xl font-bold text-gray-900 dark:text-white mb-4">
          Cookies & Tracking
        </h2>

        <p class="text-gray-600 dark:text-gray-400 mb-4">
          We do not use advertising pixels or third-party analytics platforms to track your behavior across the web.
        </p>

        <p class="text-gray-600 dark:text-gray-400">
          This site is designed to be simple, readable, and respectful of your privacy.
        </p>
      </section>

      <section>
        <h2 class="text-3xl font-bold text-gray-900 dark:text-white mb-4">
          Security & Infrastructure
        </h2>

        <p class="text-gray-600 dark:text-gray-400">
          This website uses Cloudflare and related infrastructure services to improve security, performance, and reliability. These services may use strictly necessary technical cookies or collect limited technical information required to protect and deliver the site.
        </p>
      </section>

      <section>
        <h2 class="text-3xl font-bold text-gray-900 dark:text-white mb-4">
          Contact Forms & Email
        </h2>

        <p class="text-gray-600 dark:text-gray-400">
          If you contact me through a form, email, or scheduling tool, I will receive the information you choose to provide. That information is used only for communication and related follow-up.
        </p>
      </section>

      <section>
        <h2 class="text-3xl font-bold text-gray-900 dark:text-white mb-4">
          Embedded Content
        </h2>

        <p class="text-gray-600 dark:text-gray-400">
          Some pages may contain links or embedded content from third-party websites. Those services operate under their own privacy policies and terms.
        </p>
      </section>

      <section>
        <h2 class="text-3xl font-bold text-gray-900 dark:text-white mb-4">
          Data Sharing
        </h2>

        <p class="text-gray-600 dark:text-gray-400">
          I do not sell, rent, or trade personal information.
        </p>
      </section>

      <section>
        <h2 class="text-3xl font-bold text-gray-900 dark:text-white mb-4">
          Questions
        </h2>

        <p class="text-gray-600 dark:text-gray-400">
          If you have questions about this policy, please contact me at:
        </p>

        <p class="mt-4">
          <a
            href="mailto:danryanneff@gmail.com"
            class="text-blue-600 dark:text-blue-400 hover:underline"
          >
            danryanneff@gmail.com
          </a>
        </p>
      </section>

    </div>
  </section>
</BaseLayout>