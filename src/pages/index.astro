---
import BaseLayout from '../layouts/BaseLayout.astro';
import { seoMetadata } from '../lib/constants';

const pageMetadata = seoMetadata['/'];
---

<BaseLayout
  title={pageMetadata.title}
  description={pageMetadata.description}
  ogImage={pageMetadata.ogImage}
>
  <section class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8 py-16 md:py-24">
    <div class="text-center mb-16">
      <h1 class="text-5xl md:text-6xl font-bold text-gray-900 dark:text-white mb-6">
        Good judgment in a changing world.
      </h1>
      <h2 class="text-2xl md:text-3xl text-gray-600 dark:text-gray-400 mb-8">
        Operations & Digital Builder
      </h2>
      <p class="text-lg text-gray-600 dark:text-gray-400 mb-8 max-w-3xl mx-auto">
        Conversations and clarity sessions that help thoughtful people move meaningful work forward with stronger structure and connection.
      </p>
      <div class="flex gap-4 justify-center flex-wrap">
        <a
          href="/work-with-me/"
          class="px-8 py-3 bg-blue-600 hover:bg-blue-700 dark:bg-blue-500 dark:hover:bg-blue-600 text-white font-semibold rounded-lg transition-colors"
        >
          Work with me
        </a>
        <a
          href="/contact/"
          class="px-8 py-3 border-2 border-blue-600 dark:border-blue-500 text-blue-600 dark:text-blue-400 hover:bg-blue-50 dark:hover:bg-gray-800 font-semibold rounded-lg transition-colors"
        >
          Start a conversation
        </a>
      </div>
    </div>
  </section>

  <!-- Services Section -->
  <section class="bg-gray-50 dark:bg-gray-800 py-16">
    <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
      <h2 class="text-3xl md:text-4xl font-bold text-gray-900 dark:text-white mb-12 text-center">
        What I build
      </h2>
      <div class="grid grid-cols-1 md:grid-cols-2 gap-8">
        <div class="bg-white dark:bg-gray-700 p-8 rounded-lg">
          <h3 class="text-2xl font-bold text-gray-900 dark:text-white mb-4">
            Operations
          </h3>
          <p class="text-gray-600 dark:text-gray-300 mb-4">
            Clear systems, faster decisions. Let me help you build the operational foundation your organization needs.
          </p>
          <a href="/work-with-me/" class="text-blue-600 dark:text-blue-400 hover:text-blue-800 dark:hover:text-blue-300 font-semibold">
            Learn more →
          </a>
        </div>
        <div class="bg-white dark:bg-gray-700 p-8 rounded-lg">
          <h3 class="text-2xl font-bold text-gray-900 dark:text-white mb-4">
            Digital
          </h3>
          <p class="text-gray-600 dark:text-gray-300 mb-4">
            Digital products and strategy that work. From concept to launch, let's build something meaningful together.
          </p>
          <a href="/work-with-me/" class="text-blue-600 dark:text-blue-400 hover:text-blue-800 dark:hover:text-blue-300 font-semibold">
            Learn more →
          </a>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>
