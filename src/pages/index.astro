---
import BaseLayout from '../layouts/BaseLayout.astro';
import {
  SITE_NAME,
  OG_IMAGE,
} from '../lib/constants';

const areas = [
  {
    title: 'Learning & Thinking',
    description:
      "How can technology deepen understanding without replacing our own thinking? I'm interested in AI as a partner for learning, reasoning, and creativity, but I see the danger in using AI as a shortcut instead of thinking independently.",
  },
  {
    title: 'Attention & Creativity',
    description:
      "The tools we use shape the way we think. I'm exploring how digital environments can encourage focus, play, exploration, and creative expression instead of distraction and endless consumption.",
  },
  {
    title: 'Accessibility & Participation',
    description:
      'Technology has an incredible ability to expand participation. My work with accessibility continues to shape how I think about designing tools and experiences that help more people engage fully with the world.',
  },
  {
    title: 'Digital Places',
    description:
      "Websites, online communities, and digital tools are places people inhabit. I'm interested in how these spaces influence identity, relationships, communication, and belonging, and how we can build better ones.",
  },
  {
    title: 'Organizations & Work',
    description:
      'Organizations are systems made of people, processes, and technology. I enjoy helping teams navigate complexity, improve operations, and thoughtfully adopt new technologies without losing sight of the humans involved.',
  },
  {
    title: 'Stewardship',
    description:
      "Every choice we make contributes to the technological landscape around us. Whether we create software, publish content, adopt AI, or simply decide how we spend our attention, we're helping shape the world that others will participate in tomorrow.",
  },
];

const projects = [
  {
    title: 'Mandalafy',
    description:
      'An exploration of creativity, attention, symmetry, and playful digital experiences.',
    href: '/projects/mandalafy/',
    theme: 'Creativity and attention',
  },
  {
    title: 'LandingBio',
    description:
      'An exploration of how people represent themselves and connect with others online.',
    href: '/projects/landingbio/',
    theme: 'Identity and connection',
  },
  {
    title: 'ImagineThis.Site',
    description:
      'An exploration of building, learning, and giving people practical tools to create their own place on the web.',
    href: '/projects/imaginethis-site/',
    theme: 'Learning and expression',
  },
];

const questions = [
  'When does AI strengthen our thinking, and when does it undermine it?',
  'How can technology support health, and when does it damage health?',
  'What makes a digital place feel welcoming, useful, and genuinely human?',
  'How can accessibility improve experiences for everyone?',
  'How do our individual choices shape the technological world we all share?',
];

const pageTitle = `${SITE_NAME} | Participating well in a technological world`;

const pageDescription =
  'Exploring how technology shapes learning, creativity, accessibility, relationships, organizations, and the environments we inhabit.';
---

<BaseLayout
  title={pageTitle}
  description={pageDescription}
  ogTitle={pageTitle}
  ogDescription={pageDescription}
  ogImage={OG_IMAGE}
>
  <!-- Hero -->
  <section
    class="relative overflow-hidden border-b border-gray-200 bg-white dark:border-gray-800 dark:bg-gray-900"
  >
    <!-- Decorative background -->
    <div
      class="pointer-events-none absolute inset-0"
      aria-hidden="true"
    >
      <div
        class="absolute -right-32 top-16 h-96 w-96 rounded-full bg-blue-100/70 blur-3xl dark:bg-blue-900/20"
      >
      </div>

      <div
        class="absolute -left-32 bottom-0 h-80 w-80 rounded-full bg-indigo-100/60 blur-3xl dark:bg-indigo-900/20"
      >
      </div>
    </div>

    <div
      class="relative mx-auto max-w-6xl px-4 py-20 sm:px-6 sm:py-28 lg:px-8 lg:py-32"
    >
      <div
        class="grid items-center gap-12 lg:grid-cols-[minmax(0,1.45fr)_minmax(240px,0.55fr)] lg:gap-14"
      >
        <!-- Hero copy -->
        <div class="max-w-4xl">
          <p
            class="mb-6 text-sm font-semibold uppercase tracking-[0.18em] text-blue-600 dark:text-blue-400"
          >
            An ongoing question
          </p>

          <h1
            class="text-5xl font-bold leading-[1.04] tracking-tight text-gray-900 dark:text-white sm:text-6xl lg:text-7xl"
          >
            What does it mean to participate well in a technological world?
          </h1>

          <div
            class="mt-8 max-w-3xl space-y-5 text-lg leading-8 text-gray-600 dark:text-gray-300 sm:text-xl"
          >
            <p>
              Technology is becoming part of nearly every aspect of life. It
              shapes how we learn, create, communicate, work, care for our
              health, build relationships, and understand the world around us.
            </p>

            <p>
              It also changes the environments we inhabit—both physical and
              digital.
            </p>
          </div>

          <div class="mt-10 flex flex-wrap gap-4">
            <a
              href="#explore"
              class="inline-flex items-center rounded-lg bg-blue-600 px-6 py-3 font-medium text-white transition-colors hover:bg-blue-700 focus:outline-none focus:ring-2 focus:ring-blue-500 focus:ring-offset-2 dark:focus:ring-offset-gray-900"
            >
              Explore the question
              <span class="ml-2" aria-hidden="true">↓</span>
            </a>

            <a
              href="/projects/"
              class="inline-flex items-center rounded-lg border border-gray-300 bg-white px-6 py-3 font-medium text-gray-800 transition-colors hover:border-blue-500 hover:text-blue-600 focus:outline-none focus:ring-2 focus:ring-blue-500 focus:ring-offset-2 dark:border-gray-700 dark:bg-gray-900 dark:text-gray-200 dark:hover:border-blue-400 dark:hover:text-blue-400 dark:focus:ring-offset-gray-900"
            >
              View projects
            </a>
          </div>
        </div>

        <!-- Portrait -->
        <figure
          class="mx-auto w-full max-w-xs lg:mx-0 lg:max-w-none lg:justify-self-end"
        >
          <div
            class="relative overflow-hidden rounded-[2rem] border border-gray-200 bg-gray-100 shadow-lg shadow-gray-200/60 dark:border-gray-700 dark:bg-gray-800 dark:shadow-black/20"
          >
            <img
              src="/images/dan-ryan-neff.webp"
              alt="Dan Ryan Neff outdoors"
              class="aspect-[4/5] w-full object-cover object-center"
              width="640"
              height="800"
              loading="eager"
              decoding="async"
              fetchpriority="high"
            />
          </div>

          <figcaption
            class="mt-4 text-center text-sm text-gray-500 dark:text-gray-400 lg:text-left"
          >
            Dan Ryan Neff
          </figcaption>
        </figure>
      </div>
    </div>
  </section>

  <!-- Introduction -->
  <section
    id="explore"
    class="scroll-mt-24 bg-white dark:bg-gray-900"
  >
    <div
      class="mx-auto grid max-w-6xl gap-8 px-4 py-20 sm:px-6 lg:grid-cols-[0.45fr_1fr] lg:px-8 lg:py-28"
    >
      <div>
        <p
          class="text-sm font-semibold uppercase tracking-[0.18em] text-blue-600 dark:text-blue-400"
        >
          The exploration
        </p>
      </div>

      <div class="max-w-3xl">
        <p
          class="text-3xl font-semibold leading-tight tracking-tight text-gray-900 dark:text-white sm:text-4xl"
        >
          I'm exploring what it means to use technology in ways that expand our
          capabilities while remaining thoughtful about its effects.
        </p>

        <p class="mt-7 text-lg leading-8 text-gray-600 dark:text-gray-300">
          That includes its effects on ourselves, the people around us, and the
          broader landscape we're helping create.
        </p>

        <p class="mt-5 text-lg leading-8 text-gray-600 dark:text-gray-300">
          This website is a place to explore that question through projects,
          writing, experiments, and conversation.
        </p>
      </div>
    </div>
  </section>

  <!-- Areas of exploration -->
  <section
    class="border-y border-gray-200 bg-gray-50 dark:border-gray-800 dark:bg-gray-950"
  >
    <div
      class="mx-auto max-w-6xl px-4 py-20 sm:px-6 lg:px-8 lg:py-28"
    >
      <div class="max-w-3xl">
        <p
          class="text-sm font-semibold uppercase tracking-[0.18em] text-blue-600 dark:text-blue-400"
        >
          Areas of exploration
        </p>

        <h2
          class="mt-5 text-4xl font-bold tracking-tight text-gray-900 dark:text-white sm:text-5xl"
        >
          Technology is not separate from life.
        </h2>

        <p class="mt-6 text-lg leading-8 text-gray-600 dark:text-gray-300">
          It increasingly shapes how we think, create, connect, work, and move
          through the world.
        </p>
      </div>

      <div class="mt-14 grid gap-6 md:grid-cols-2">
        {
          areas.map((area, index) => (
            <article
              class="rounded-2xl border border-gray-200 bg-white p-7 transition-colors dark:border-gray-800 dark:bg-gray-900 sm:p-8"
            >
              <div class="flex items-start gap-4">
                <span
                  class="pt-1 font-mono text-xs text-gray-400 dark:text-gray-500"
                >
                  {String(index + 1).padStart(2, '0')}
                </span>

                <div>
                  <h3
                    class="text-xl font-bold text-gray-900 dark:text-white"
                  >
                    {area.title}
                  </h3>

                  <p
                    class="mt-4 leading-7 text-gray-600 dark:text-gray-300"
                  >
                    {area.description}
                  </p>
                </div>
              </div>
            </article>
          ))
        }
      </div>
    </div>
  </section>

  <!-- Physical and virtual landscapes -->
  <section class="bg-white dark:bg-gray-900">
    <div
      class="mx-auto grid max-w-6xl gap-10 px-4 py-20 sm:px-6 lg:grid-cols-2 lg:items-center lg:px-8 lg:py-28"
    >
      <div>
        <p
          class="text-sm font-semibold uppercase tracking-[0.18em] text-blue-600 dark:text-blue-400"
        >
          Physical and virtual landscapes
        </p>

        <h2
          class="mt-5 text-4xl font-bold tracking-tight text-gray-900 dark:text-white sm:text-5xl"
        >
          I pay attention to the places people inhabit.
        </h2>
      </div>

      <div
        class="space-y-5 text-lg leading-8 text-gray-600 dark:text-gray-300"
      >
        <p>
          Some of those places are physical: neighborhoods, organizations,
          communities, cities, and natural environments.
        </p>

        <p>
          Others are virtual: websites, platforms, online communities,
          information ecosystems, and AI-shaped spaces.
        </p>

        <p>
          I'm interested in how these landscapes influence behavior, attention,
          relationships, access, and belonging—and in how our actions help
          shape them for other people.
        </p>
      </div>
    </div>
  </section>

  <!-- Projects -->
  <section
    class="border-y border-gray-200 bg-gray-50 dark:border-gray-800 dark:bg-gray-950"
  >
    <div
      class="mx-auto max-w-6xl px-4 py-20 sm:px-6 lg:px-8 lg:py-28"
    >
      <div
        class="flex flex-col gap-6 lg:flex-row lg:items-end lg:justify-between"
      >
        <div class="max-w-3xl">
          <p
            class="text-sm font-semibold uppercase tracking-[0.18em] text-blue-600 dark:text-blue-400"
          >
            Selected projects
          </p>

          <h2
            class="mt-5 text-4xl font-bold tracking-tight text-gray-900 dark:text-white sm:text-5xl"
          >
            Different ways of exploring the same question.
          </h2>
        </div>

        <a
          href="/projects/"
          class="font-medium text-blue-600 transition-colors hover:text-blue-700 dark:text-blue-400 dark:hover:text-blue-300"
        >
          View all projects
          <span class="ml-1" aria-hidden="true">→</span>
        </a>
      </div>

      <div class="mt-14 grid gap-6 lg:grid-cols-3">
        {
          projects.map((project) => (
            <a
              href={project.href}
              class="group flex min-h-80 flex-col justify-between rounded-2xl border border-gray-200 bg-white p-8 transition-all hover:-translate-y-1 hover:border-blue-300 hover:shadow-lg dark:border-gray-800 dark:bg-gray-900 dark:hover:border-blue-700"
            >
              <div>
                <p
                  class="text-xs font-semibold uppercase tracking-[0.16em] text-blue-600 dark:text-blue-400"
                >
                  {project.theme}
                </p>

                <h3
                  class="mt-5 text-3xl font-bold tracking-tight text-gray-900 dark:text-white"
                >
                  {project.title}
                </h3>

                <p
                  class="mt-5 leading-7 text-gray-600 dark:text-gray-300"
                >
                  {project.description}
                </p>
              </div>

              <span
                class="mt-10 font-medium text-gray-900 dark:text-white"
              >
                Explore project

                <span
                  class="ml-2 inline-block transition-transform group-hover:translate-x-1"
                  aria-hidden="true"
                >
                  →
                </span>
              </span>
            </a>
          ))
        }
      </div>
    </div>
  </section>

  <!-- Current questions -->
  <section class="bg-gray-900 text-white dark:bg-black">
    <div
      class="mx-auto grid max-w-6xl gap-12 px-4 py-20 sm:px-6 lg:grid-cols-[0.6fr_1fr] lg:px-8 lg:py-28"
    >
      <div>
        <p
          class="text-sm font-semibold uppercase tracking-[0.18em] text-blue-400"
        >
          Current questions
        </p>

        <h2
          class="mt-5 text-4xl font-bold tracking-tight sm:text-5xl"
        >
          Questions I'm actively thinking about.
        </h2>
      </div>

      <ol class="border-t border-gray-700">
        {
          questions.map((question, index) => (
            <li
              class="grid grid-cols-[2rem_1fr] gap-4 border-b border-gray-700 py-6 sm:grid-cols-[3rem_1fr]"
            >
              <span class="pt-1 font-mono text-xs text-gray-500">
                {String(index + 1).padStart(2, '0')}
              </span>

              <p class="text-xl leading-8 text-gray-200 sm:text-2xl">
                {question}
              </p>
            </li>
          ))
        }
      </ol>
    </div>
  </section>

  <!-- Invitation -->
  <section class="bg-white dark:bg-gray-900">
    <div
      class="mx-auto max-w-6xl px-4 py-20 sm:px-6 lg:px-8 lg:py-28"
    >
      <div
        class="rounded-3xl border border-gray-200 bg-gray-50 px-6 py-14 dark:border-gray-800 dark:bg-gray-950 sm:px-10 lg:px-14 lg:py-20"
      >
        <div class="max-w-4xl">
          <p
            class="text-sm font-semibold uppercase tracking-[0.18em] text-blue-600 dark:text-blue-400"
          >
            Let's explore
          </p>

          <h2
            class="mt-5 text-4xl font-bold tracking-tight text-gray-900 dark:text-white sm:text-5xl"
          >
            Great conversations begin with curiosity.
          </h2>

          <p
            class="mt-6 max-w-3xl text-lg leading-8 text-gray-600 dark:text-gray-300"
          >
            Whether you're building a project, navigating change in your
            organization, curious about AI, or simply asking similar questions,
            I'd enjoy connecting.
          </p>

          <a
            href="/contact/"
            class="mt-9 inline-flex items-center rounded-lg bg-blue-600 px-6 py-3 font-medium text-white transition-colors hover:bg-blue-700 focus:outline-none focus:ring-2 focus:ring-blue-500 focus:ring-offset-2 dark:focus:ring-offset-gray-950"
          >
            Start a conversation
            <span class="ml-2" aria-hidden="true">→</span>
          </a>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>