---
const navigation = [
  {
    label: "About",
    href: "/about/",
  },
  {
    label: "Projects",
    href: "/projects/",
  },
  {
    label: "Contact",
    href: "/contact/",
  },
];
---

<header
  class="bg-white/90 dark:bg-gray-900/90 backdrop-blur border-b border-gray-200 dark:border-gray-800 sticky top-0 z-50 transition-colors"
>
  <nav
    class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8 py-4"
    aria-label="Primary navigation"
  >
    <div class="flex items-center justify-between">
      <a
        href="/"
        class="text-xl md:text-2xl font-bold text-gray-900 dark:text-white hover:text-blue-600 dark:hover:text-blue-400 transition-colors"
      >
        DanRyanNeff.com
      </a>

      <div class="hidden md:flex items-center gap-8">
        {
          navigation.map((item) => (
            <a
              href={item.href}
              class="text-gray-700 dark:text-gray-300 hover:text-blue-600 dark:hover:text-blue-400 font-medium transition-colors"
            >
              {item.label}
            </a>
          ))
        }
      </div>
    </div>
  </nav>
</header>