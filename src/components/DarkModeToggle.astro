---
// Dark mode toggle
---

<script>
  const initDarkMode = () => {
    const darkMode = localStorage.getItem('darkMode');
    const isDark =
      darkMode === 'true' ||
      (!darkMode && window.matchMedia('(prefers-color-scheme: dark)').matches);

    document.documentElement.classList.toggle('dark', isDark);
  };

  initDarkMode();

  window.addEventListener('storage', (e) => {
    if (e.key === 'darkMode') initDarkMode();
  });

  document.addEventListener('DOMContentLoaded', () => {
    const button = document.createElement('button');

    button.id = 'dark-mode-toggle';
    button.setAttribute('aria-label', 'Toggle dark mode');
    button.className =
      'fixed bottom-4 right-4 z-40 flex h-11 w-11 items-center justify-center rounded-full bg-gray-200 text-gray-800 shadow-sm hover:bg-gray-300 dark:bg-gray-700 dark:text-gray-100 dark:hover:bg-gray-600 transition-colors';

    const renderIcon = () => {
      const isDark = document.documentElement.classList.contains('dark');

      button.innerHTML = isDark
        ? `
          <svg class="h-5 w-5" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24" aria-hidden="true">
            <path stroke-linecap="round" stroke-linejoin="round" d="M21 12.79A9 9 0 1111.21 3 7 7 0 0021 12.79z"></path>
          </svg>
        `
        : `
          <svg class="h-5 w-5" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24" aria-hidden="true">
            <path stroke-linecap="round" stroke-linejoin="round" d="M12 3v2m0 14v2m9-9h-2M5 12H3m15.36-6.36l-1.41 1.41M7.05 16.95l-1.41 1.41m0-12.72l1.41 1.41m9.9 9.9l1.41 1.41"></path>
            <circle cx="12" cy="12" r="4"></circle>
          </svg>
        `;
    };

    renderIcon();

    button.addEventListener('click', () => {
      const isDark = document.documentElement.classList.contains('dark');
      const newState = !isDark;

      document.documentElement.classList.toggle('dark', newState);
      localStorage.setItem('darkMode', String(newState));
      renderIcon();
    });

    document.body.appendChild(button);
  });
</script>

<style>
  @media (prefers-reduced-motion: reduce) {
    #dark-mode-toggle {
      transition: none !important;
    }
  }
</style>