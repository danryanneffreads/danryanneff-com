---
import { SITE_NAME } from "../lib/constants";

const footerLinks = [
  {
    label: "About",
    href: "/about/",
  },
  {
    label: "Projects",
    href: "/projects/",
  },
  {
    label: "Contact",
    href: "/contact/",
  },
];

const currentYear = new Date().getFullYear();
---

<footer
  class="bg-gray-50 dark:bg-gray-900 border-t border-gray-200 dark:border-gray-800 mt-16 transition-colors"
>
  <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8 py-12">
    <div class="flex flex-col gap-8 md:flex-row md:items-start md:justify-between">
      <div>
        <a
          href="/"
          class="text-lg font-bold text-gray-900 dark:text-white hover:text-blue-600 dark:hover:text-blue-400 transition-colors"
        >
          {SITE_NAME}
        </a>

        <p class="mt-2 text-sm text-gray-600 dark:text-gray-400">
          Exploring ideas by building them.
        </p>
      </div>

      <nav aria-label="Footer navigation">
        <ul class="flex flex-col gap-3 md:flex-row md:gap-6">
          {
            footerLinks.map((link) => (
              <li>
                <a
                  href={link.href}
                  class="text-gray-600 dark:text-gray-400 hover:text-blue-600 dark:hover:text-blue-400 transition-colors"
                >
                  {link.label}
                </a>
              </li>
            ))
          }
        </ul>
      </nav>
    </div>

    <div class="border-t border-gray-200 dark:border-gray-800 mt-10 pt-8">
      <p class="text-sm text-gray-600 dark:text-gray-400">
        &copy; {currentYear} {SITE_NAME}
      </p>
    </div>
  </div>
</footer>