---
import { footerLinks, SITE_NAME } from '../lib/constants';
---

<footer class="bg-gray-50 dark:bg-gray-900 border-t border-gray-200 dark:border-gray-800 mt-16 transition-colors">
  <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8 py-12">
    <div class="grid grid-cols-1 md:grid-cols-3 gap-8 mb-8">
      <div>
        <h3 class="text-lg font-bold text-gray-900 dark:text-white mb-2">
          {SITE_NAME}
        </h3>
        <p class="text-gray-600 dark:text-gray-400 text-sm">
          Good judgment in a changing world.
        </p>
      </div>

      <div>
        <h4 class="font-semibold text-gray-900 dark:text-white mb-4">Links</h4>
        <ul class="space-y-2">
          {footerLinks.map((link) => (
            <li>
              <a href={link.href} class="text-gray-600 dark:text-gray-400 hover:text-blue-600 dark:hover:text-blue-400 transition-colors">
                {link.label}
              </a>
            </li>
          ))}
        </ul>
      </div>

      <div>
        <h4 class="font-semibold text-gray-900 dark:text-white mb-4">Start here</h4>
        <a href="/contact/" class="inline-block px-6 py-2 bg-blue-600 hover:bg-blue-700 text-white font-medium rounded-lg transition-colors">
          Start a conversation
        </a>
      </div>
    </div>

    <div class="border-t border-gray-200 dark:border-gray-800 pt-8">
      <p class="text-center text-gray-600 dark:text-gray-400 text-sm">
        &copy; 2026 {SITE_NAME}. All rights reserved.
      </p>
    </div>
  </div>
</footer>